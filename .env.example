# FunPay-Core engine configuration.
#
# Copy to .env and fill in real values. .env is gitignored.
#
# FP_* values come from browser DevTools after manual login at funpay.com
# (Application → Cookies for golden_key/phpsessid/golden_seal; Network tab for
# user_id and csrf_token on a runner request). golden_seal expires — refresh
# manually when the engine reports auth_lost.
#
# ENGINE_TOKEN is a shared secret between the engine and the bot. Generate a
# random string and use the same value in the bot's .env. Empty token is fatal
# — the engine refuses to start unprotected.
#
# ENGINE_LISTEN is the bind address. Default 127.0.0.1:8731 = localhost only.

# FunPay auth (from browser DevTools)
FP_GOLDEN_KEY=
FP_PHPSESSID=
FP_GOLDEN_SEAL=
FP_USER_ID=
FP_CSRF_TOKEN=

# REST server
ENGINE_TOKEN=
ENGINE_LISTEN=127.0.0.1:8731
